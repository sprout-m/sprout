VITE_API_URL=http://localhost:8080

# Hedera / HashPack wallet integration
# Get a free project ID at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=

# HTS USDC token ID for your network
# Testnet: 0.0.429274  |  Mainnet: 0.0.456858
VITE_HEDERA_USDC_TOKEN_ID=

# testnet or mainnet
VITE_HEDERA_NETWORK=testnet

# Platform account that holds PoF (Proof of Funds) deposits from buyers
VITE_HEDERA_POF_ACCOUNT_ID=

# NFT collection token ID for listing ownership NFTs
# Buyers are pre-associated with this token during USDC deposit so the operator
# can transfer the NFT to them later without TOKEN_NOT_ASSOCIATED_TO_ACCOUNT.
VITE_HEDERA_NFT_COLLECTION_ID=
