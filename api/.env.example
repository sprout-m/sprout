APP_PORT=8080

# PostgreSQL connection string
DATABASE_URL=postgres://meridian:meridian@localhost:5432/meridian?sslmode=disable

# JWT signing secret — use a random 32+ character string in production
JWT_SECRET=change-me-to-a-long-random-secret

# Hedera — mirrors the hedera package config
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ACCOUNT_ID=0.0.XXXXX
HEDERA_OPERATOR_PRIVATE_KEY=
HEDERA_USDC_TOKEN_ID=

# HTS NFT collection used for listing ownership tokens.
# Create once with tokens.CreateListingNFTCollection and paste the token ID here.
HEDERA_NFT_COLLECTION_ID=
