APP_PORT=8080

# PostgreSQL connection string
DATABASE_URL=postgres://sprout:sprout@localhost:5432/sprout?sslmode=disable

# JWT signing secret — use a random 32+ character string in production
JWT_SECRET=change-me-to-a-long-random-secret

# Hedera
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ACCOUNT_ID=0.0.XXXXX
HEDERA_OPERATOR_PRIVATE_KEY=

# AWS KMS — used for cryptographic signing of milestone approvals
AWS_REGION=us-east-1
AWS_KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/your-key-id
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
