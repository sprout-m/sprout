# Hedera network: "testnet" or "mainnet"
HEDERA_NETWORK=testnet

# Platform operator account — pays for all platform-initiated transactions
HEDERA_OPERATOR_ACCOUNT_ID=0.0.XXXXX
HEDERA_OPERATOR_PRIVATE_KEY=

# Platform public key — used as the arbiter key in 2-of-3 escrow threshold key lists
HEDERA_PLATFORM_PUBLIC_KEY=

# USDC HTS token ID
# Mainnet: verify the current Circle-issued USDC token ID on hashscan.io
# Testnet: deploy a test stablecoin using tokens.CreateTestStablecoin and paste its ID here
HEDERA_USDC_TOKEN_ID=
